{
  "name": "vovk-examples",
  "version": "3.0.22",
  "description": "Vovk examples",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "vovk"
  ],
  "scripts": {
    "test": "npm run lint",
    "ncu": "npx npm-check-updates -u && npm i",
    "predev": "npm run update-mdx-github-codeblocks",
    "dev": "vovk dev --next-dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "patch": "npm t && npm version patch",
    "minor": "npm t && npm version minor",
    "BREAKING-major": "npm t && npm version major",
    "postversion": "npm run bundle && npm publish ./dist && git push && git push --tags",
    "generate": "vovk generate",
    "bundle": "NODE_ENV=production vovk bundle",
    "prebuild": "vovk generate",
    "postbuild": "pagefind --site .next/server/app --output-path public/_pagefind",
    "vercel-build": "npm run build",
    "update-mdx-github-codeblocks": "node --experimental-strip-types ./scripts/updateMDXFilesWithGithubContent.ts"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": true,
    "printWidth": 120
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finom/vovk-examples.git"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/react": "^3.0.136",
    "@hookform/resolvers": "^5.2.2",
    "@scalar/api-reference-react": "^0.9.13",
    "@tanstack/react-query": "^5.94.5",
    "@valibot/to-json-schema": "^1.6.0",
    "ai": "6.0.134",
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "arktype": "^2.2.0",
    "bright": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash": "^4.17.23",
    "lucide-react": "^0.577.0",
    "next": "^16.2.1",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "openai": "^6.32.0",
    "openapi3-ts": "^4.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-loading-skeleton": "^3.5.0",
    "react-to-string": "^0.1.1",
    "tailwind-merge": "^3.5.0",
    "tsdown": "^0.19.0",
    "valibot": "^1.3.1",
    "vovk": "^3.1.3",
    "vovk-ajv": "^0.0.2",
    "vovk-client": "^1.0.0",
    "yup": "^1.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "pagefind": "^1.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vovk-cli": "^0.1.2",
    "vovk-python": "^0.0.1",
    "vovk-rust": "^0.0.1"
  }
}
